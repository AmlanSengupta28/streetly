VITE_API_BASE_URL=http://localhost:4000/api

# Supabase Storage (photo uploads) — Project URL + anon public key, from
# Dashboard → Project Settings → API. The anon key is safe to expose in
# frontend code; it can only do what your storage policies allow.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=changeme
VITE_SUPABASE_STORAGE_BUCKET=streetly-photos
